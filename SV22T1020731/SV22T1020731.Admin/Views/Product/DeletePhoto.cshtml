@model ProductPhoto
@{
    int productId = Model?.ProductID ?? 0;
}
@section PageToolBar {
    <a href="~/Product/Edit/@productId#photos" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0">
                    <i class="bi bi-exclamation-triangle me-1"></i>
                    Xóa hình ảnh mặt hàng
                </h5>
            </div>
            <div class="card-body">
                <form method="post" action="~/Product/DeletePhoto/@productId?photoId=@Model.PhotoID">

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-circle me-1"></i>
                        Bạn có chắc chắn muốn xóa hình ảnh này không?
                        Dữ liệu sau khi xóa sẽ <strong>không thể khôi phục</strong>.
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Hình ảnh</label>
                        <div class="col-sm-9">
                            <img src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-thumbnail"
                                 style="max-height:150px;"
                                 onerror="this.src='/images/products/nophoto.png'" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Mô tả</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" value="@Model.Description" disabled />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number" class="form-control" value="@Model.DisplayOrder" disabled />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Trạng thái</label>
                        <div class="col-sm-9 pt-2">
                            @if (Model.IsHidden)
                            {
                                <span class="badge bg-secondary">Ẩn</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Hiện</span>
                            }
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-sm-9 offset-sm-3 text-end">
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash me-1"></i>
                                Xác nhận xóa
                            </button>
                            <a href="~/Product/Edit/@productId#photos" class="btn btn-secondary ms-2">
                                <i class="bi bi-arrow-left me-1"></i>
                                Bỏ qua
                            </a>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
