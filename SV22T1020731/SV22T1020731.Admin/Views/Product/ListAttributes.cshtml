@model List<ProductAttribute>
@{
    Layout = null;
    int productId = Model.FirstOrDefault()?.ProductID ?? 0;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="attributes" class="card-title mb-0">
                            <i class="bi bi-list-check me-2"></i>
                            Thuộc tính mặt hàng
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/CreateAttribute/@productId">
                            <i class="bi bi-plus"></i>
                            Thêm thuộc tính
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                @if (!Model.Any())
                {
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-list-check fs-3 d-block mb-1"></i>
                        Chưa có thuộc tính nào
                    </div>
                }
                else
                {
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-secondary">
                            <tr>
                                <th>Tên thuộc tính</th>
                                <th>Giá trị</th>
                                <th style="width:120px" class="text-center">Thứ tự</th>
                                <th style="width:100px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var attr in Model)
                            {
                                <tr>
                                    <td>@attr.AttributeName</td>
                                    <td>@attr.AttributeValue</td>
                                    <td class="text-center">@attr.DisplayOrder</td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary"
                                           href="~/Product/EditAttribute/@productId?attributeId=@attr.AttributeID"
                                           title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger"
                                           href="~/Product/DeleteAttribute/@productId?attributeId=@attr.AttributeID"
                                           title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>

