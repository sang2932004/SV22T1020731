@model ProductPhoto
@{
    int productId = Model?.ProductID ?? 0;
}
@section PageToolBar {
    <button type="submit" form="formEditPhoto" class="btn btn-primary">
        <i class="bi bi-save me-1"></i>
        Lưu ảnh
    </button>
    <a href="~/Product/Edit/@productId#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left me-1"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0">@ViewBag.Title</h5>
            </div>
            <div class="card-body">
                @Html.ValidationMessage("error", new { @class = "text-danger" })
                <form id="formEditPhoto" method="post"
                      action="~/Product/SavePhoto"
                      enctype="multipart/form-data">

                    <input type="hidden" asp-for="PhotoID" />
                    <input type="hidden" asp-for="ProductID" />
                    <input type="hidden" asp-for="Photo" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">
                            Ảnh @(Model.PhotoID == 0 ? "" : "(để trống nếu không thay đổi)")
                        </label>
                        <div class="col-sm-9">
                            <input type="file"
                                   name="uploadPhoto"
                                   class="form-control"
                                   accept="image/*"
                                   onchange="previewImage(this)"
                                   data-img-preview="imgPreview" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Xem trước</label>
                        <div class="col-sm-9">
                            <img id="imgPreview"
                                 src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-thumbnail"
                                 style="max-height:200px;"
                                 onerror="this.src='/images/products/nophoto.png'" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Mô tả</label>
                        <div class="col-sm-9">
                            <input type="text" asp-for="Description" class="form-control"
                                   placeholder="Mô tả ngắn về ảnh này" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number" asp-for="DisplayOrder"
                                   class="form-control" min="1" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-semibold">Trạng thái</label>
                        <div class="col-sm-9 pt-2">
                            <div class="form-check form-switch">
                                <input class="form-check-input" asp-for="IsHidden"
                                       type="checkbox" id="IsHidden" />
                                <label class="form-check-label" for="IsHidden">
                                    Ẩn ảnh này
                                </label>
                            </div>
                        </div>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
