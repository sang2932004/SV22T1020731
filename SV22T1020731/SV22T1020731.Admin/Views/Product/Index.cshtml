@model ProductSearchInput?
@{
    ViewBag.Title = "Quản lý Mặt hàng";
}
@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch"
              method="get"
              action="~/Product/Search"
              data-target="searchResult"
              onsubmit="paginationSearch(event, this, 1)">
            <input type="hidden" asp-for="PageSize" />

            <div class="row g-2">

                <!-- Loại hàng -->
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select class="form-select" asp-for="CategoryID">
                        <option value="0">-- Tất cả --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var item in ViewBag.Categories.DataItems)
                            {
                                <option value="@item.CategoryID">
                                    @item.CategoryName
                                </option>
                            }
                        }
                    </select>
                </div>

                <!-- Nhà cung cấp -->
                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select class="form-select" asp-for="SupplierID">
                        <option>-- Tất cả --</option>
                        @foreach (var item in ViewBag.Suppliers.DataItems)
                        {
                            <option value="@item.SupplierID">
                                @item.SupplierName
                            </option>
                        }
                    </select>
                </div>

                <!-- Khoảng giá -->
                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text"
                               asp-for="MinPrice"
                               class="form-control money-input"
                               placeholder="Từ" />
                        <span class="input-group-text">-</span>
                        <input type="text"
                               asp-for="MaxPrice"
                               class="form-control money-input"
                               placeholder="Đến" />
                    </div>
                </div>

                <!-- Tên mặt hàng -->
                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text"
                               asp-for="SearchValue"
                               class="form-control"
                               placeholder="Tên mặt hàng..." autofocus />

                        <button class="btn btn-info d-flex align-items-center">
                            <i class="bi bi-search me-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
        });
    </script>
}