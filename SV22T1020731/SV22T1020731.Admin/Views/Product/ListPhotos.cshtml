@model List<ProductPhoto>
@{
    Layout = null;
    int productId = Model.FirstOrDefault()?.ProductID ?? 0;
}
<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4">
            <div class="card-header">
                <div class="row">
                    <div class="col">
                        <h6 id="photos" class="mb-0">
                            <i class="bi bi-images me-2"></i>
                            Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/CreatePhoto/@productId">
                            <i class="bi bi-plus-circle me-1"></i>
                            Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                @if (!Model.Any())
                {
                    <div class="text-center text-muted py-3">
                        <i class="bi bi-images fs-3 d-block mb-1"></i>
                        Chưa có ảnh nào
                    </div>
                }
                else
                {
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-secondary">
                            <tr>
                                <th style="width:120px">Ảnh</th>
                                <th>Mô tả</th>
                                <th style="width:120px" class="text-center">Thứ tự</th>
                                <th style="width:120px" class="text-center">Hiển thị</th>
                                <th style="width:100px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="text-center">
                                        <img src="~/images/products/@item.Photo"
                                             class="img-thumbnail"
                                             style="max-height:80px;"
                                             onerror="this.src='/images/products/"nophoto.png" />
                                    </td>
                                    <td>@item.Description</td>
                                    <td class="text-center">@item.DisplayOrder</td>
                                    <td class="text-center">
                                        @if (item.IsHidden)
                                        {
                                            <span class="badge bg-secondary">Ẩn</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">Hiện</span>
                                        }
                                    </td>
                                    <td class="text-center text-nowrap">
                                        <a class="btn btn-sm btn-primary"
                                           href="~/Product/EditPhoto/@productId?photoId=@item.PhotoID"
                                           title="Chỉnh sửa">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a class="btn btn-sm btn-danger"
                                           href="~/Product/DeletePhoto/@productId?photoId=@item.PhotoID"
                                           title="Xóa">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>