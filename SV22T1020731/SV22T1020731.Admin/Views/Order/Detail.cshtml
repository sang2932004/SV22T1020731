@model OrderViewInfo
@using SV22T1020731.Models.Sales
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    var details = ViewBag.Details as List<SV22T1020731.Models.Sales.OrderDetailViewInfo> ?? new List<SV22T1020731.Models.Sales.OrderDetailViewInfo>();
    decimal totalAmount = details.Sum(d => d.TotalPrice);

    bool isNew      = Model.Status == OrderStatusEnum.New;
    bool isAccepted = Model.Status == OrderStatusEnum.Accepted;
    bool isShipping = Model.Status == OrderStatusEnum.Shipping;
    bool isFinished = Model.Status == OrderStatusEnum.Completed
                   || Model.Status == OrderStatusEnum.Rejected
                   || Model.Status == OrderStatusEnum.Cancelled;
}

@section PageToolBar {
    <div class="btn-group">
        <button type="button"
                class="btn btn-primary dropdown-toggle"
                data-bs-toggle="dropdown">
            <i class="bi bi-gear me-1"></i>
            Xử lý đơn hàng
        </button>
        <ul class="dropdown-menu">
            @if (isNew)
            {
                <li>
                    <a class="dropdown-item open-modal"
                       href="~/Order/Accept/@Model.OrderID">
                        <i class="bi bi-check-circle me-1 text-primary"></i>
                        Duyệt đơn hàng
                    </a>
                </li>
                <li>
                    <a class="dropdown-item text-danger open-modal"
                       href="~/Order/Reject/@Model.OrderID">
                        <i class="bi bi-x-circle me-1"></i>
                        Từ chối đơn hàng
                    </a>
                </li>
            }
            @if (isNew || isAccepted)
            {
                <li><hr class="dropdown-divider"></li>
                <li>
                    <a class="dropdown-item text-warning open-modal"
                       href="~/Order/Cancel/@Model.OrderID">
                        <i class="bi bi-slash-circle me-1"></i>
                        Hủy đơn hàng
                    </a>
                </li>
            }
            @if (isAccepted)
            {
                <li>
                    <a class="dropdown-item open-modal"
                       href="~/Order/Shipping/@Model.OrderID">
                        <i class="bi bi-truck me-1 text-info"></i>
                        Chuyển giao hàng
                    </a>
                </li>
            }
            @if (isShipping)
            {
                <li>
                    <a class="dropdown-item open-modal"
                       href="~/Order/Finish/@Model.OrderID">
                        <i class="bi bi-flag-fill me-1 text-success"></i>
                        Hoàn tất đơn hàng
                    </a>
                </li>
            }
            @if (isFinished)
            {
                <li>
                    <li class="dropdown-item text-muted disabled">
                        <i class="bi bi-lock me-1"></i>
                        Đơn hàng đã kết thúc
                    </li>
                </li>
            }
        </ul>
    </div>

    @if (isNew)
    {
        <a href="~/Order/Delete/@Model.OrderID"
           class="btn btn-danger ms-1 open-modal">
            <i class="bi bi-trash"></i>
            Xóa
        </a>
    }

    <a href="~/Order" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<!-- TRẠNG THÁI ĐƠN HÀNG -->
@{
    string alertClass = "alert-secondary";
    string alertIcon  = "bi-circle";
    string statusText = "";

    if (Model.Status == OrderStatusEnum.New)
    {
        alertClass = "alert-info";
        alertIcon  = "bi-hourglass-split";
        statusText = "Đơn hàng mới — chờ xử lý";
    }
    else if (Model.Status == OrderStatusEnum.Accepted)
    {
        alertClass = "alert-primary";
        alertIcon  = "bi-check-circle-fill";
        statusText = $"Đã duyệt lúc {Model.AcceptTime:dd/MM/yyyy HH:mm}";
    }
    else if (Model.Status == OrderStatusEnum.Shipping)
    {
        alertClass = "alert-warning";
        alertIcon  = "bi-truck";
        statusText = $"Đang giao hàng từ {Model.ShippedTime:dd/MM/yyyy HH:mm}";
    }
    else if (Model.Status == OrderStatusEnum.Completed)
    {
        alertClass = "alert-success";
        alertIcon  = "bi-check-circle-fill";
        statusText = $"Đã hoàn tất lúc {Model.FinishedTime:dd/MM/yyyy HH:mm}";
    }
    else if (Model.Status == OrderStatusEnum.Rejected)
    {
        alertClass = "alert-danger";
        alertIcon  = "bi-x-circle-fill";
        statusText = $"Đã bị từ chối lúc {Model.FinishedTime:dd/MM/yyyy HH:mm}";
    }
    else if (Model.Status == OrderStatusEnum.Cancelled)
    {
        alertClass = "alert-secondary";
        alertIcon  = "bi-slash-circle-fill";
        statusText = $"Đã bị hủy lúc {Model.FinishedTime:dd/MM/yyyy HH:mm}";
    }
}

<div class="alert @alertClass d-flex align-items-center mb-3">
    <i class="bi @alertIcon fs-4 me-2"></i>
    <div>
        <strong>Trạng thái đơn hàng:</strong> @statusText
    </div>
</div>

<!-- THÔNG TIN ĐƠN HÀNG -->
<div class="card card-primary card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-receipt me-2"></i>
            Thông tin đơn hàng
        </h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Mã đơn hàng</div>
            <div class="col-md-3">@Model.OrderID</div>
            <div class="col-md-3 fw-bold">Ngày lập</div>
            <div class="col-md-3">@string.Format("{0:dd/MM/yyyy HH:mm}", Model.OrderTime)</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Nhân viên phụ trách</div>
            <div class="col-md-3">@(string.IsNullOrEmpty(Model.EmployeeName) ? "Chưa có" : Model.EmployeeName)</div>
            <div class="col-md-3 fw-bold">Ngày nhận đơn</div>
            <div class="col-md-3">@(Model.AcceptTime.HasValue ? Model.AcceptTime.Value.ToString("dd/MM/yyyy HH:mm") : "Chưa duyệt")</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN KHÁCH HÀNG -->
<div class="card card-info card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-person me-2"></i>
            Thông tin khách hàng
        </h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Khách hàng</div>
            <div class="col-md-3">@(string.IsNullOrEmpty(Model.CustomerName) ? "Khách lẻ" : Model.CustomerName)</div>
            <div class="col-md-3 fw-bold">Tên giao dịch</div>
            <div class="col-md-3">@Model.CustomerContactName</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Email</div>
            <div class="col-md-9">@Model.CustomerEmail</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-9">@Model.CustomerPhone</div>
        </div>
    </div>
</div>

<!-- THÔNG TIN GIAO HÀNG -->
<div class="card card-success card-outline mb-3">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-truck me-2"></i>
            Thông tin giao hàng
        </h5>
    </div>
    <div class="card-body ps-4 pe-4">
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Người giao hàng</div>
            <div class="col-md-3">@(string.IsNullOrEmpty(Model.ShipperName) ? "Chưa phân công" : Model.ShipperName)</div>
            <div class="col-md-3 fw-bold">Điện thoại</div>
            <div class="col-md-3">@Model.ShipperPhone</div>
        </div>
        <div class="row mb-2">
            <div class="col-md-3 fw-bold">Địa chỉ giao hàng</div>
            <div class="col-md-9">@Model.DeliveryAddress</div>
        </div>
        <div class="row">
            <div class="col-md-3 fw-bold">Tỉnh / Thành</div>
            <div class="col-md-9">@Model.DeliveryProvince</div>
        </div>
    </div>
</div>

<!-- DANH SÁCH MẶT HÀNG -->
<div class="card card-secondary card-outline">
    <div class="card-header">
        <h5 class="card-title mb-0">
            <i class="bi bi-box-seam me-2"></i>
            Danh sách mặt hàng
        </h5>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-secondary text-center">
                <tr>
                    <th>STT</th>
                    <th>Tên hàng</th>
                    <th>ĐVT</th>
                    <th>Số lượng</th>
                    <th>Giá</th>
                    <th>Thành tiền</th>
                    @if (isNew)
                    {
                        <th style="width:90px"></th>
                    }
                </tr>
            </thead>
            <tbody>
                @{ int stt = 0; }
                @foreach (var item in details)
                {
                    stt++;
                    <tr>
                        <td class="text-center">@stt</td>
                        <td>@item.ProductName</td>
                        <td class="text-center">@item.Unit</td>
                        <td class="text-center">@item.Quantity</td>
                        <td class="text-end">@item.SalePrice.ToString("N0")</td>
                        <td class="text-end">@item.TotalPrice.ToString("N0")</td>
                        @if (isNew)
                        {
                            <td class="text-center text-nowrap">
                                <a href="~/Order/EditCartItem?productId=@item.ProductID"
                                   class="btn btn-sm btn-primary open-modal"
                                   title="Chỉnh sửa">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a href="~/Order/DeleteCartItem?productId=@item.ProductID"
                                   class="btn btn-sm btn-danger open-modal"
                                   title="Xóa">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        }
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <th colspan="@(isNew ? 6 : 5)" class="text-end">Tổng cộng</th>
                    <th class="text-end">@totalAmount.ToString("N0")</th>
                    @if (isNew)
                    {
                        <th></th>
                    }
                </tr>
            </tfoot>
        </table>
    </div>
</div>

@section Styles {
    <style>
        .card-body .row {
            border-bottom: 1px dotted #646464;
            padding-top: 6px;
            padding-bottom: 6px;
        }
    </style>
}
