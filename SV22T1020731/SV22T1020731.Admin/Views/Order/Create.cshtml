@model ProductSearchInput
@{
    ViewBag.Title = "Lập đơn hàng";
}

<div class="row">
    <!-- Tìm kiếm & chọn mặt hàng -->
    <div class="col-4">
        <div class="card card-outline card-primary h-100">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-search"></i>
                    Lựa chọn hàng cần bán
                </h5>
            </div>

            <div class="card-body">
                <!-- Search -->
                <form id="formSearch" class="mb-3"
                      method="get"
                      action="~/Order/SearchProduct"
                      data-target="searchResult"
                      onsubmit="paginationSearch(event, this, 1)">

                    <input type="hidden" asp-for="PageSize" />

                    <div class="input-group">
                        <input class="form-control"
                               asp-for="SearchValue"
                               placeholder="Nhập tên mặt hàng cần tìm" autofocus />
                        <button class="btn btn-primary">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>
                <div id="searchResult"></div>
                
            </div>

            <div class="card-footer">
            </div>
        </div>
    </div>

    <!-- Giỏ hàng và thông tin khách hàng -->
    <div class="col-8">
        <!-- Giỏ hàng -->
        <div class="row">
            <div class="col-12" id="cart">
                
            </div>
        </div>
        <!-- Thông tin khách hàng và nơi giao hàng -->
        <div class="row mt-3">
            <div class="col-12">
                <div class="card card-outline card-info">
                    <div class="card-header">
                        <h5 class="mb-0">
                            <i class="bi bi-person"></i>
                            Thông tin khách hàng & nơi giao hàng
                        </h5>
                    </div>

                    <div class="card-body">
                        <form onsubmit="createOrder(event, this)">
                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Khách hàng</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="customerID">
                                        <option value="0">-- Chọn khách hàng --</option>
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Tỉnh/thành</label>
                                <div class="col-md-10">
                                    <select class="form-select" name="provice" asp-items="await SelectListHelper.ProvincesAsync()">
                                        
                                    </select>
                                </div>
                            </div>

                            <div class="row mb-3">
                                <label class="col-md-2 col-form-label">Địa chỉ</label>
                                <div class="col-md-10">
                                    <textarea class="form-control" name="address"></textarea>
                                </div>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check-circle"></i>
                                    Lập đơn hàng
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
 
@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            paginationSearch(null, document.getElementById("formSearch"), @Model.Page);
            showCart();
        });

        function showCart() {
            fetch('/Order/ShowCart', {
                method: 'GET'
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Lỗi khi tải giỏ hàng');
                }
                return response.text(); // lấy HTML
            })
            .then(html => {
                document.getElementById('cart').innerHTML = html;
            })
            .catch(error => {
                console.error(error);
                document.getElementById('cart').innerHTML = '<p>Lỗi tải giỏ hàng</p>';
            });
        }

        function addCartItem(event, form) {
            // Ngăn form submit mặc định
            event.preventDefault();

            // Lấy dữ liệu từ form
            const formData = new FormData(form);

            // Gửi POST lên API
            fetch('/Order/AddCartItem', {
                method: 'POST',
                body: formData
            })
            .then(response => response.json())
            .then(data => {
                if (data.code === 0) {
                    // Hiển thị lỗi
                    alert(data.message);
                } else {
                    // Thành công -> gọi hàm showCart()
                    showCart();
                }
            })
            .catch(error => {
                console.error('Lỗi:', error);
                alert('Có lỗi xảy ra, vui lòng thử lại!');
            });
        }

        function deleteCartItem(productID) {
            fetch(`/Order/DeleteCartItem?productId=${encodeURIComponent(productID)}`, {
                method: 'POST'
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Request thất bại');
                }
                return response.json(); // nếu API có trả JSON
            })
            .then(data => {
                // Có thể kiểm tra thêm nếu API trả code/message
                // Ví dụ:
                // if (data.code === 0) {
                //     alert(data.message);
                //     return;
                // }

                // Sau khi xóa xong -> load lại giỏ hàng
                showCart();
            })
            .catch(error => {
                console.error('Lỗi:', error);
                alert('Không thể xóa sản phẩm!');
            });
        }

        function clearCart() {
            fetch('/Order/ClearCart', {
                method: 'POST'
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Request thất bại');
                }
                return response.json(); // nếu API trả JSON
            })
            .then(data => {
                // Nếu API có trả {code, message} thì kiểm tra:
                // if (data.code === 0) {
                //     alert(data.message);
                //     return;
                // }

                // Thành công -> cập nhật lại giỏ hàng
                showCart();
            })
            .catch(error => {
                console.error('Lỗi:', error);
                alert('Không thể xóa toàn bộ giỏ hàng!');
            });
        }

        function updateCartItem(event, form) {
            // Ngăn submit mặc định
            event.preventDefault();

            const formData = new FormData(form);

            fetch('/Order/UpdateCartItem', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Request thất bại');
                }
                return response.json();
            })
            .then(data => {
                if (data.code === 0) {
                    alert(data.message);
                    return;
                }

                // Đóng modal Bootstrap 5
                const modalElement = document.getElementById('dialogModal');
                const modalInstance = bootstrap.Modal.getInstance(modalElement)
                                      || new bootstrap.Modal(modalElement);
                modalInstance.hide();

                // Reload lại giỏ hàng
                showCart();
            })
            .catch(error => {
                console.error('Lỗi:', error);
                alert('Có lỗi xảy ra!');
            });
        }

        function createOrder(event, form) {
            // Ngăn submit mặc định
            event.preventDefault();

            const formData = new FormData(form);

            fetch('/Order/CreatrOrder', {
                method: 'POST',
                body: formData
            })
            .then(response => {
                if (!response.ok) {
                    throw new Error('Request thất bại');
                }
                return response.json();
            })
            .then(data => {
                if (data.code === 0) {
                    // Lỗi
                    alert(data.message);
                    return;
                }

                // Thành công -> chuyển trang
                window.location.href = `/Order/Detail/${data.code}`;
            })
            .catch(error => {
                console.error('Lỗi:', error);
                alert('Có lỗi xảy ra!');
            });
        }
    </script>
}
<script>
    function createOrder() {

        var customerID = $("select[name='CustomerID']").val();
        var province = $("select[name='Province']").val();
        var address = $("input[name='Address']").val();

        $.ajax({
            url: '/Order/CreateOrder',
            type: 'POST',
            data: {
                customerID: customerID,
                province: province,
                address: address
            },
            success: function (res) {

                if (res.code > 0) {
                    alert("Tạo đơn hàng thành công!");
                    window.location.href = "/Order";
                }
                else {
                    alert(res.message);
                }
            },
            error: function () {
                alert("Lỗi server!");
            }
        });
    }
</script>