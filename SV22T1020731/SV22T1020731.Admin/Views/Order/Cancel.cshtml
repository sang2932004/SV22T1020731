@model OrderViewInfo
@{
    Layout = null;
}
<form method="post" action="~/Order/Cancel/@Model.OrderID">
    <div class="modal-header text-bg-warning">
        <strong class="modal-title">
            <i class="bi bi-slash-circle me-1"></i>
            Hủy đơn hàng
        </strong>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
    </div>

    <div class="modal-body">
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                @foreach (var err in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@err.ErrorMessage</div>
                }
            </div>
        }
        <div class="alert alert-warning d-flex align-items-center">
            <i class="bi bi-exclamation-triangle me-2 fs-5"></i>
            <div>
                Bạn có chắc chắn muốn <strong>hủy</strong> đơn hàng
                <strong>#@Model.OrderID</strong> không?<br />
                <small>Hành động này không thể hoàn tác.</small>
            </div>
        </div>
        <div class="row g-2">
            <div class="col-6"><span class="fw-bold">Khách hàng:</span> @(string.IsNullOrEmpty(Model.CustomerName) ? "Khách lẻ" : Model.CustomerName)</div>
            <div class="col-6"><span class="fw-bold">Ngày lập:</span> @string.Format("{0:dd/MM/yyyy HH:mm}", Model.OrderTime)</div>
            <div class="col-12"><span class="fw-bold">Trạng thái hiện tại:</span>
                @(Model.Status == SV22T1020731.Models.Sales.OrderStatusEnum.New ? "Mới tạo" : "Đã duyệt")
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-warning">
            <i class="bi bi-slash-circle me-1"></i> Xác nhận hủy
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
            Đóng
        </button>
    </div>
</form>
